{
  "name": "ctrlchecks-worker",
  "version": "1.0.0",
  "description": "Unified Node.js backend for CtrlChecks - migrated from Supabase Edge Functions",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node scripts/startup-validation.js && nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc && npm run export:schemas && npm run copy:data",
    "copy:data": "node scripts/copy-data-files.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "predev": "npm run type-check",
    "prebuild": "npm run type-check",
    "fix-types": "node scripts/fix-types.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:contracts": "jest src/core/contracts/ --passWithNoTests",
    "test:compiler": "jest test/stage5-compiler.test.ts --passWithNoTests",
    "test:e2e": "jest test/e2e/ --passWithNoTests",
    "test:integration": "jest src/services/ai/__tests__/end-to-end-workflow-integration.test.ts src/services/ai/__tests__/workflow-execution-integration.test.ts --passWithNoTests",
    "benchmark": "ts-node scripts/performance-benchmark.ts",
    "benchmark:save": "ts-node scripts/performance-benchmark.ts --save-only",
    "benchmark:run": "ts-node scripts/performance-benchmark.ts --run-only",
    "migrate:workflows": "ts-node scripts/migrate-existing-workflows.ts",
    "verify:accuracy": "node scripts/verify-workflow-accuracy.js",
    "verify:n8n": "node scripts/verify-n8n-accuracy.js",
    "verify:workflows": "node scripts/verify-workflow-accuracy.js",
    "export:schemas": "ts-node scripts/export-node-schemas.ts",
    "build:schemas": "ts-node scripts/generate-node-schemas.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "memory:setup": "node scripts/setup-memory-system.js || bash scripts/setup-memory-system.sh",
    "test-data:generate": "ts-node scripts/generate-test-data.ts",
    "test-data:verify": "ts-node scripts/verify-test-data.ts",
    "test-data:comprehensive": "ts-node scripts/generate-comprehensive-test-data.ts",
    "train:ollama": "ts-node scripts/train-ollama-model.ts",
    "dev:worker": "ts-node scripts/start-worker-service.ts",
    "start:worker": "node dist/scripts/start-worker-service.js",
    "retry-execution": "ts-node scripts/retry-stuck-execution.ts",
    "train:prepare-data": "ts-node scripts/train-ollama-model.ts --prepare-only",
    "train:ollama-ft": "ts-node scripts/train-ollama-model.ts --method=ollama-ft",
    "train:unsloth": "echo 'Run: python worker/scripts/train-with-unsloth.py'",
    "verify:fine-tuned": "ts-node scripts/verify-fine-tuned-model.ts",
    "create:model": "powershell -ExecutionPolicy Bypass -File scripts/create-model-remote.ps1",
    "generate-training-workflows": "ts-node scripts/generate-training-workflows.ts",
    "train:generate": "ts-node scripts/generate-training-dataset.ts",
    "train:validate": "ts-node scripts/validate-training-data.ts",
    "test:workflows": "ts-node scripts/test-workflow-generation.ts",
    "test:workflows:high": "ts-node scripts/test-workflow-generation.ts --priority=high",
    "test:workflows:triggers": "ts-node scripts/test-workflow-generation.ts --category=triggers",
    "test:workflows:logic": "ts-node scripts/test-workflow-generation.ts --category=logic",
    "test:workflows:crm": "ts-node scripts/test-workflow-generation.ts --category=crm",
    "train:prepare": "ts-node scripts/prepare-fine-tuning-data.ts",
    "test:prompts": "ts-node scripts/test-workflow-generation.ts",
    "test:run": "ts-node scripts/run-workflow-tests.ts",
    "test:direct": "ts-node --project tsconfig.scripts.json scripts/test-workflow-direct.ts",
    "test:4prompts": "node scripts/test-4-prompts.cjs",
    "validate:enhancements": "ts-node scripts/validate-enhancements.ts",
    "test:15-workflows": "ts-node scripts/test-15-workflows-execution.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "@octokit/rest": "^20.1.2",
    "@prisma/client": "^5.7.1",
    "@supabase/supabase-js": "^2.39.0",
    "airtable": "^0.12.2",
    "amqplib": "^0.10.3",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "googleapis": "^128.0.0",
    "ioredis": "^5.9.3",
    "lru-cache": "^10.1.0",
    "mongodb": "^7.1.0",
    "mssql": "^12.2.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.17.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "ollama": "^0.5.7",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "redis": "^4.6.12",
    "snowflake-sdk": "^2.3.4",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^9.0.1",
    "vm2": "^3.10.3",
    "winston": "^3.11.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/lru-cache": "^7.10.9",
    "@types/mssql": "^9.1.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
