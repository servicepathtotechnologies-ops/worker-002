          "default": "POST"
        },
        "path": {
          "type": "string",
          "description": "Webhook path"
        }
      },
      "inputs": [],
      "outputs": ["main"],
      "credentials": []
    },
    "emailSend": {
      "nodeType": "n8n-nodes-base.emailSend",
      "displayName": "Send Email",
      "category": "communication",
      "subcategory": "email",
      "description": "Send email messages",
      "capabilities": ["notification", "email"],
      "requiredConfig": {
        "to": {
          "type": "string",
