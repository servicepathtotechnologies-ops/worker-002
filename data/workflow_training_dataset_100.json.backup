    {
      "id": "workflow_1",
      "category": "Notification",
      "goal": "send notification to slack",
      "phase1": {
        "step1": {
          "userPrompt": "send notification to slack"
        },
        "step3": {
          "systemPrompt": "Send notifications to specified channels based on triggers and conditions.",
          "wordCount": 10,
          "temperature": 0.2
        },
        "step4": {
          "requirements": {
            "primaryGoal": "send notification to slack",
            "platforms": [
              "Slack"
            ],
            "credentialsRequired": [
              "SLACK_WEBHOOK_URL"
            ],
            "complexityLevel": "Simple"
          }
        },
        "step5": {
          "structure": {
            "flowType": "Simple linear flow",
            "description": "Trigger: manual_trigger → Step 1: slack_message"
          },
          "selectedNodes": [
            "manual_trigger",
            "slack_message"
          ],
          "nodeConfigurations": {
            "manual_trigger": {},
            "slack_message": {
              "webhookUrl": "{{SLACK_WEBHOOK_URL}}",
              "channel": "#general",
              "message": "Notification message"
            }
          },
          "connections": [
            "trigger → slack_message"
          ]
        }
      },
      "phase2": {
        "executionInitialization": {
          "executionId": "created",
          "iterationCount": 0
        },
        "executionLoop": [
          {
            "iteration": 1,
            "execution": "Executing slack_message node",
            "stateUpdated": "State updated after slack_message"
          }
        ],
        "executionFinalization": {
          "totalIterations": 2,
          "goalAchieved": true
        }
      }
    },
