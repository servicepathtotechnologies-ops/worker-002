      "credentials": ["GOOGLE_GEMINI_API_KEY"],
      "requiredFields": ["model", "prompt"]
    },
    {
      "id": "agent_1",
      "type": "ai_agent",
      "config": {
        "model": "google_gemini",
        "systemPrompt": "You are a helpful assistant with conversation memory."
      },
      "credentials": ["GOOGLE_GEMINI_API_KEY"],
      "requiredFields": ["model", "systemPrompt"]
    }
  ],
  "edges": [
    { "source": "chat_trigger_1", "target": "memory_1" },
