# ============================================
# CtrlChecks Worker Service - Environment Variables
# ============================================
# Copy this file to .env and update values for your environment
# Production: Update PUBLIC_BASE_URL, CORS_ORIGIN, and ALLOWED_ORIGINS
# Local: Use default values

# ============================================
# Environment Mode
# ============================================
NODE_ENV=production

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
SUPABASE_URL=https://nvrrqvlqnnvlihtlgmzn.supabase.co
