# REQUIRED - Supabase Configuration
# ============================================
SUPABASE_URL=https://nvrrqvlqnnvlihtlgmzn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im52cnJxdmxxbm52bGlodGxnbXpuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTQ2NDkwMywiZXhwIjoyMDgxMDQwOTAzfQ.s78wC4CLp2ci8nGgvMNCk-ePBALIcNdlf_jFS9Oevqg
# Also support VITE_ prefix for shared .env files
VITE_SUPABASE_URL=https://nvrrqvlqnnvlihtlgmzn.supabase.co
