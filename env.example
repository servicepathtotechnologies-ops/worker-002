VITE_SUPABASE_URL=https://nvrrqvlqnnvlihtlgmzn.supabase.co
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im52cnJxdmxxbm52bGlodGxnbXpuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTQ2NDkwMywiZXhwIjoyMDgxMDQwOTAzfQ.s78wC4CLp2ci8nGgvMNCk-ePBALIcNdlf_jFS9Oevqg
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im52cnJxdmxxbm52bGlodGxnbXpuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjU0NjQ5MDMsImV4cCI6MjA4MTA0MDkwM30.3So6zpF15ORuOF-R6YY2ya1XE9bTCjnsvAxf1B7HZMo

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:Supabase%40123@db.nvrrqvlqnnvlihtlgmzn.supabase.co:5432/postgres

# ============================================
# Worker Service Configuration
# ============================================
PORT=3001
PUBLIC_BASE_URL=https://worker.ctrlchecks.ai
WORKER_ID=worker-aws-1

# ============================================
# Ollama & FastAPI Configuration
# ============================================
# Ollama server URL (via FastAPI proxy)
OLLAMA_BASE_URL=http://ollama.ctrlchecks.ai:8000
# FastAPI Ollama proxy service URL (for /process endpoint)
FASTAPI_OLLAMA_URL=http://ollama.ctrlchecks.ai:8000
PYTHON_BACKEND_URL=http://ollama.ctrlchecks.ai:8000

# ============================================
# CORS Configuration
# ============================================
# Production: https://ctrlchecks.ai,https://*.vercel.app
# Local: http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173
CORS_ORIGIN=https://ctrlchecks.ai,https://*.vercel.app
ALLOWED_ORIGINS=https://ctrlchecks.ai,https://*.vercel.app

# ============================================
# WebSocket Configuration
# ============================================
# Production: wss://worker.ctrlchecks.ai
# Local: ws://localhost:3001
WEBSOCKET_URL=wss://worker.ctrlchecks.ai
WEBSOCKET_PATH=/ws/chat
CHAT_FORWARDING_ENABLED=true
MAX_CHAT_MESSAGE_SIZE=5000
CHAT_HEARTBEAT_INTERVAL=30000
CHAT_DEBUG=false

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARN, ERROR, SILENT
LOG_LEVEL=INFO

# ============================================
# Execution Configuration
# ============================================
PROCESS_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
RETRY_BASE_SECONDS=1.0
RETRY_MAX_SECONDS=20.0

# ============================================
# Memory System Configuration
# ============================================
MEMORY_CACHE_SIZE=100
NODE_OUTPUTS_CACHE_SIZE=100
ENABLE_MEMORY_LOGGING=false

# ============================================
# Retention Policies (in days)
# ============================================
EXECUTION_RETENTION_DAYS=30
WORKFLOW_RETENTION_DAYS=365
LOG_RETENTION_DAYS=7
ENABLE_AUTO_PRUNE=true

# ============================================
# Vector Search Configuration
# ============================================
ENABLE_VECTOR_SEARCH=true
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSIONS=1536
SIMILARITY_THRESHOLD=0.7

# ============================================
# Contract Enforcement & Validation
# ============================================
CONTRACT_VALIDATION_ENABLED=true
AUTO_REPAIR_ENABLED=true
SCHEMA_VALIDATION_STRICT=true
NODE_LIBRARY_PATH=./public/node-library.json
VALIDATION_LOGGING=false
TEST_WORKFLOWS_PATH=./test_workflows

# ============================================
# Workflow Execution Mode
# ============================================
# SAFE_MODE: Always require user confirmation
# FAST_MODE: Auto-confirm if confidence score > 0.95
WORKFLOW_EXECUTION_MODE=SAFE_MODE

# ============================================
# Optional - External API Keys
# ============================================
# Only needed if using external AI services
# All AI calls route through Ollama by default
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here
# HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ============================================
# Optional - Google OAuth
# ============================================
# Only needed if using Google integrations (Gmail, Sheets, etc.)
# GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# ============================================
# Optional - Object Storage (S3/MinIO)
# ============================================
# Only needed if you expect node outputs larger than 1MB
# If not configured, large payloads will be stored in database
# S3_ENDPOINT=minio:9000  # For MinIO, or leave empty for AWS S3
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET_NAME=workflow-executions
# S3_REGION=us-east-1
