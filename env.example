# ============================================
# CtrlChecks Worker Service - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im52cnJxdmxxbm52bGlodGxnbXpuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjU0NjQ5MDMsImV4cCI6MjA4MTA0MDkwM30.3So6zpF15ORuOF-R6YY2ya1XE9bTCjnsvAxf1B7HZMo
# ============================================
# Ollama Configuration
# ============================================
# Ollama server URL
# Local: http://localhost:11434
# AWS FastAPI: http://ollama.ctrlchecks.ai:8000
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Worker Service Configuration
# ============================================
# Port for the worker service (default: 3001)
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
WORKER_ID=worker-local

# ============================================
# WebSocket Configuration (Chat Trigger)
# ============================================
# WebSocket URL for chat connections (default: ws://localhost:3001)
# Production: wss://your-domain.com
WEBSOCKET_URL=ws://localhost:3001
# WebSocket path for chat (default: /ws/chat)
WEBSOCKET_PATH=/ws/chat
# Enable chat forwarding from AI agent to UI (default: true)
CHAT_FORWARDING_ENABLED=true
# Maximum chat message size in bytes (default: 5000)
MAX_CHAT_MESSAGE_SIZE=5000
# Chat heartbeat interval in milliseconds (default: 30000)
CHAT_HEARTBEAT_INTERVAL=30000
# Enable debug logging for chat WebSocket (default: false)
CHAT_DEBUG=false

# ============================================
# FastAPI Ollama Service (Required for Production)
# ============================================
# FastAPI Ollama proxy service URL (for /process endpoint)
# AWS Production: http://ollama.ctrlchecks.ai:8000
# Local Development: http://localhost:8000
# For local testing with AWS: http://ollama.ctrlchecks.ai:8000
FASTAPI_OLLAMA_URL=http://ollama.ctrlchecks.ai:8000
PYTHON_BACKEND_URL=http://ollama.ctrlchecks.ai:8000

# ============================================
# CORS Configuration
# ============================================
# Allowed origins (use * for all, or comma-separated list)
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=*

# ============================================
# Optional - Advanced Configuration
# ============================================
LOG_LEVEL=INFO
PROCESS_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
RETRY_BASE_SECONDS=1.0
RETRY_MAX_SECONDS=20.0

# ============================================
# Optional - External API Keys (Not Required)
# ============================================
# These are optional and only needed if using external AI services
# All AI calls now route through Ollama by default
# OPENAI_API_KEY=  # Required for embeddings (vector search)
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=

# ============================================
# Memory System Configuration
# ============================================
# Database URL for Prisma (PostgreSQL)
# Use your Supabase connection string or PostgreSQL URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ctrlchecks

# Memory cache size (number of workflows to cache)
MEMORY_CACHE_SIZE=100

# Retention policies (in days)
EXECUTION_RETENTION_DAYS=30
WORKFLOW_RETENTION_DAYS=365
LOG_RETENTION_DAYS=7
ENABLE_AUTO_PRUNE=true

# Vector embeddings configuration
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSIONS=1536
SIMILARITY_THRESHOLD=0.7
ENABLE_VECTOR_SEARCH=true

# ============================================
# Optional - Google OAuth (if using Google integrations)
# ============================================
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================
# Phase 1: Contract Enforcement & Validation
# ============================================
# Enable contract validation (default: true)
CONTRACT_VALIDATION_ENABLED=true
# Enable auto-repair for workflows (default: true)
AUTO_REPAIR_ENABLED=true
# Strict schema validation (default: true)
SCHEMA_VALIDATION_STRICT=true
# Path to node library JSON export (optional)
NODE_LIBRARY_PATH=./public/node-library.json

# ============================================
# Testing & Verification
# ============================================
# Path to test workflows for validation
TEST_WORKFLOWS_PATH=./test_workflows
# Enable validation logging (default: false)
VALIDATION_LOGGING=false

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARN, ERROR, SILENT
# - DEBUG: Show all logs including verbose workflow validation
# - INFO: Show informational messages (default in development)
# - WARN: Show only warnings and errors (default in production)
# - ERROR: Show only errors
# - SILENT: No logs
LOG_LEVEL=INFO

# ============================================
# CtrlChecks Worker Service - Environment Variables
# ============================================
# LOCAL TESTING CONFIGURATION
# No nginx required - runs directly on localhost:3001

# ============================================
# Environment Mode
# ============================================
NODE_ENV=development

