# ============================================
# Ollama Configuration - REMOTE
# ============================================
# Ollama server URL (via FastAPI proxy on remote server)
# NOTE: FastAPI uses HTTP (not HTTPS) on port 8000
OLLAMA_BASE_URL=http://ollama.ctrlchecks.ai:8000

# ============================================
# Worker Service Configuration - LOCAL
# ============================================
# Port for the worker service (default: 3001)
PORT=3001
# Public base URL (for local testing, use localhost)
PUBLIC_BASE_URL=http://localhost:3001
WORKER_ID=worker-local

# ============================================
# FastAPI Ollama Service - REMOTE
# ============================================
# FastAPI Ollama proxy service URL (for /process endpoint)
# Remote server: http://ollama.ctrlchecks.ai:8000 (HTTP, not HTTPS)
FASTAPI_OLLAMA_URL=http://ollama.ctrlchecks.ai:8000
PYTHON_BACKEND_URL=http://ollama.ctrlchecks.ai:8000

# ============================================
# CORS Configuration - LOCAL DEVELOPMENT
# ============================================
# Allowed origins for local development (Vite dev server)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# ============================================
# Advanced Configuration
# ============================================
LOG_LEVEL=INFO
PROCESS_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
RETRY_BASE_SECONDS=1.0
RETRY_MAX_SECONDS=20.0


MEMORY_CACHE_SIZE=100
EXECUTION_RETENTION_DAYS=30
WORKFLOW_RETENTION_DAYS=365
ENABLE_AUTO_PRUNE=true

# Vector Embeddings (optional - only if you want similarity search)
# OPENAI_API_KEY=your-openai-api-key-here
ENABLE_VECTOR_SEARCH=true

# ============================================
# Enterprise State Architecture Configuration
# ============================================
# Window System cache size (number of node outputs to keep in memory)
# Default: 100 (adjust based on workflow complexity)
NODE_OUTPUTS_CACHE_SIZE=100

# Enable production logging for state management
# Set to 'true' to see cache hit rates, persistence stats, etc.
ENABLE_MEMORY_LOGGING=false

# ============================================
# Optional - Object Storage (for large payloads >1MB)
# ============================================
# Only needed if you expect node outputs larger than 1MB
# If not configured, large payloads will be stored in database
# S3_ENDPOINT=minio:9000  # For MinIO, or leave empty for AWS S3
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET_NAME=workflow-executions
# S3_REGION=us-east-1
DATABASE_URL=postgresql://postgres:Supabase%40123@db.nvrrqvlqnnvlihtlgmzn.supabase.co:5432/postgres
# ============================================
# Optional - External API Keys (Not Required)
# ============================================
# These are optional and only needed if using external AI services
# All AI calls now route through Ollama by default
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=

# ============================================
# Workflow Execution Mode
# ============================================
# Execution mode for workflow confirmation:
# - SAFE_MODE (default): Always require user confirmation before workflow execution
# - FAST_MODE: Auto-confirm if confidence score > 0.95
# WORKFLOW_EXECUTION_MODE=SAFE_MODE
# WORKFLOW_EXECUTION_MODE=FAST_MODE

# ============================================
# Optional - Google OAuth (if using Google integrations)
# ============================================
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# ============================================
# WebSocket Configuration (Chat Trigger)
# ============================================
# WebSocket URL for chat connections (default: ws://localhost:3001)
# Production: wss://your-domain.com
WEBSOCKET_URL=ws://localhost:3001
# WebSocket path for chat (default: /ws/chat)
WEBSOCKET_PATH=/ws/chat
# Enable chat forwarding from AI agent to UI (default: true)
CHAT_FORWARDING_ENABLED=true
# Maximum chat message size in bytes (default: 5000)
MAX_CHAT_MESSAGE_SIZE=5000
# Chat heartbeat interval in milliseconds (default: 30000)
CHAT_HEARTBEAT_INTERVAL=30000
# Enable debug logging for chat WebSocket (default: false)
CHAT_DEBUG=true

DATABASE_URL=postgresql://postgres:Supabase%40123@db.nvrrqvlqnnvlihtlgmzn.supabase.co:5432/postgres
