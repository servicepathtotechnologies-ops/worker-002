# ============================================
# CtrlChecks Worker Service - Environment Variables
# ============================================
# AWS PRODUCTION CONFIGURATION
# Deployed at: worker.ctrlchecks.ai
# Nginx handles SSL termination and reverse proxy
GEMINI_API_KEY=your_gemini_api_key_here
# Razorpay test/live keys (use test keys for dummy checkout)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# ============================================
# Environment Mode
# ============================================
NODE_ENV=development

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Also support VITE_ prefix for shared .env files
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
BUILD_TIME_LLM_KEY_SUGGESTION=true
# ============================================
# REQUIRED - Database Configuration
# ============================================
# Database URL for Prisma (PostgreSQL)
# Use your Supabase connection string
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ============================================
# Ollama Configuration - REMOTE
# ============================================
# Ollama server URL (via FastAPI proxy on remote server)
# NOTE: FastAPI uses HTTP (not HTTPS) on port 8000

# ============================================
# Fine-Tuned Model Configuration
# ============================================
# Enable fine-tuned model for workflow generation (set to 'true' after training)
USE_FINE_TUNED_MODEL=true
# Name of your fine-tuned model (default: ctrlchecks-workflow-builder)
FINE_TUNED_MODEL=ctrlchecks-workflow-builder


# ============================================
# Worker Service Configuration - AWS PRODUCTION
# ============================================
# Port for the worker service (default: 3001)
PORT=3001
# Public base URL (AWS production deployment)
# PUBLIC_BASE_URL=https://worker.ctrlchecks.ai
PUBLIC_BASE_URL=http://127.0.0.1:3001
# WORKER_ID=worker-aws-1
WORKER_ID=worker-local

# ============================================
# FastAPI Ollama Service - REMOTE
# ============================================
# FastAPI Ollama proxy service URL (for /process endpoint)
# Remote server: http://ollama.ctrlchecks.ai:8000 (HTTP, not HTTPS)
# VITE_OLLAMA_BASE_URL=http://ollama.ctrlchecks.ai:8000
# FASTAPI_OLLAMA_URL=http://ollama.ctrlchecks.ai:8000
# PYTHON_BACKEND_URL=http://ollama.ctrlchecks.ai:8000
# ============================================
# CORS Configuration - PRODUCTION
# ============================================
# Allowed origins for production (Vercel frontend)
CORS_ORIGIN=https://ctrlchecks.ai,https://www.ctrlchecks.ai,https://*.vercel.app,http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,https://ctrlchecks.ai,https://*.vercel.app,https://www.ctrlchecks.ai

ENCRYPTION_KEY=replace_with_64_char_hex_key

SMART_PLANNER_ENABLED=true
# Intent-authority guards for staged rollout:
# - shadow: log violations only
# - warn/strict: block violating generation/execution paths
ENABLE_INTENT_AUTHORITY_GUARDS=true
INTENT_AUTHORITY_ENFORCEMENT_MODE=shadow
# ============================================
# Debug & Development
# ============================================
DEBUG=true
DEBUG_GMAIL_MAPPING=true
# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
# ============================================
# Advanced Configuration
# ============================================

PROCESS_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
RETRY_BASE_SECONDS=1.0
RETRY_MAX_SECONDS=20.0
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
NOTION_OAUTH_CLIENT_ID=your_notion_client_id
NOTION_OAUTH_CLIENT_SECRET=your_notion_client_secret
TWITTER_OAUTH_CLIENT_ID=your_client_id
TWITTER_OAUTH_CLIENT_SECRET=your_client_secret
# Space-separated OAuth 2.0 scopes. Default: users.read offline.access (works on Basic/Essential).
# Add tweet.read / tweet.write after your X app has the right access level (tweet.write needs Elevated):
# TWITTER_OAUTH_SCOPES=users.read tweet.read tweet.write offline.access
TWITTER_OAUTH_SCOPES=
# ============================================
# Optional - Fine-Tuned Model Configuration
# ============================================
# Enable fine-tuned model for workflow generation
USE_FINE_TUNED_MODEL=true
# Name of your fine-tuned model (default: ctrlchecks-workflow-builder)
FINE_TUNED_MODEL=ctrlchecks-workflow-builder

# ============================================
# Optional - Advanced Configuration
# ============================================
# Smart Planner (enable advanced workflow planning)
SMART_PLANNER_ENABLED=true

# Logging level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
DEBUG_MODE=true
DEBUG_NODE_LOOKUPS=true        # Log successful lookups
DEBUG_NODE_REGISTRATION=true   # Log each node registration

# Process timeout in seconds (default: 1800 = 30 minutes)
PROCESS_TIMEOUT_SECONDS=1800
# Safe mode (default) - always require confirmation
WORKFLOW_EXECUTION_MODE=SAFE_MODE

# Fast mode - auto-confirm if confidence > 0.95
# WORKFLOW_EXECUTION_MODE=FAST_MODE
# WebSocket path for chat (default: /ws/chat)
WEBSOCKET_PATH=/ws/chat

# Enable chat forwarding from AI agent to UI
CHAT_FORWARDING_ENABLED=true

# Maximum chat message size in bytes
MAX_CHAT_MESSAGE_SIZE=5000

# Chat heartbeat interval in milliseconds
CHAT_HEARTBEAT_INTERVAL=30000

# Enable debug logging for chat WebSocket
CHAT_DEBUG=true


# ============================================
# Optional - External API Keys (Not Required)
# ============================================
# These are optional and only needed if using external AI services
# Primary runtime AI provider: Gemini (GEMINI_API_KEY)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=

# ============================================
# Optional - Google OAuth (if using Google integrations)
# ============================================
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================
# REMOVED VARIABLES (Not needed or duplicates)
# ============================================
# 
# ❌ REMOVED - Duplicates:
# - VITE_SUPABASE_URL (SUPABASE_URL is used)
# - VITE_SUPABASE_SERVICE_ROLE_KEY (SUPABASE_SERVICE_ROLE_KEY is used)
# - VITE_SUPABASE_ANON_KEY (not used in worker)
# - OLLAMA_ENDPOINT (duplicate of FASTAPI_OLLAMA_URL)
# - ALLOWED_ORIGINS (duplicate of CORS_ORIGIN)
# 
# ❌ REMOVED - Not found in code:
# - RETRY_BASE_SECONDS
# - RETRY_MAX_SECONDS
# - WEBSOCKET_URL
# - WEBSOCKET_PATH
# - CHAT_FORWARDING_ENABLED
# - MAX_CHAT_MESSAGE_SIZE
# - CHAT_HEARTBEAT_INTERVAL
# - CHAT_DEBUG